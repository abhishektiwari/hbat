@article{xiao_proteinligand_2023,
	title = {Protein{\textendash}{Ligand} {CH}-$\pi$ {Interactions}: {Structural} {Informatics}, {Energy} {Function} {Development}, and {Docking} {Implementation}},
	volume = {19},
	issn = {1549-9618},
	shorttitle = {Protein{\textendash}{Ligand} {CH}-$\pi$ {Interactions}},
	url = {https://doi.org/10.1021/acs.jctc.3c00300},
	doi = {10.1021/acs.jctc.3c00300},
	abstract = {Here, we develop an empirical energy function based on quantum mechanical data for the interaction between methane and benzene that captures the contribution from CH-$\pi$ interactions. Such interactions are frequently observed in protein{\textendash}ligand crystal structures, particularly for carbohydrate ligands, but have been hard to quantify due to the absence of a model for CH-$\pi$ interactions in typical molecular mechanical force fields or docking scoring functions. The CH-$\pi$ term was added to the AutoDock Vina (AD VINA) scoring function enabling its performance to be evaluated against a cohort of more than 1600 occurrences in 496 experimental structures of protein{\textendash}ligand complexes. By employing a conformational grid search algorithm, inclusion of the CH-$\pi$ term was shown to improve the prediction of the preferred orientation of flexible ligands in protein-binding sites and to enhance the detection of carbohydrate-binding sites that display CH-$\pi$ interactions. Last but not least, this term was also shown to improve docking performance for the CASF-2016 benchmark set and a carbohydrate set.},
	number = {16},
	urldate = {2025-08-08},
	journal = {Journal of Chemical Theory and Computation},
	author = {Xiao, Yao and Woods, Robert J.},
	month = aug,
	year = {2023},
