	pages = {5503--5515},
	file = {Full Text PDF:/Users/abhishektiwari/Zotero/storage/IB4EE72N/Xiao and Woods - 2023 - Protein{\textendash}Ligand CH-$\pi$ Interactions Structural Informatics, Energy Function Development, and Docking I.pdf:application/pdf},
}

