	keywords = {Biophysical chemistry, Structural biology},
	pages = {78},
	file = {Full Text PDF:/Users/abhishektiwari/Zotero/storage/SQ84Q3IL/Rahim et al. - 2017 - Reciprocal carbonyl{\textendash}carbonyl interactions in small molecules and proteins.pdf:application/pdf},
}

