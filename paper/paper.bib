	pages = {e31486},
	file = {Full Text PDF:/Users/abhishektiwari/Zotero/storage/L3WDHA5L/Vernon et al. - Pi-Pi contacts are an overlooked protein feature relevant to phase separation.pdf:application/pdf},
}

