	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/anie.201007560},
	doi = {10.1002/anie.201007560},
	abstract = {This review describes a multidimensional treatment of molecular recognition phenomena involving aromatic rings in chemical and biological systems. It summarizes new results reported since the appearance of an earlier review in 2003 in host{\textendash}guest chemistry, biological affinity assays and biostructural analysis, data base mining in the Cambridge Structural Database (CSD) and the Protein Data Bank (PDB), and advanced computational studies. Topics addressed are arene{\textendash}arene, perfluoroarene{\textendash}arene, S...aromatic, cation{\textendash}$\pi$, and anion{\textendash}$\pi$ interactions, as well as hydrogen bonding to $\pi$ systems. The generated knowledge benefits, in particular, structure-based hit-to-lead development and lead optimization both in the pharmaceutical and in the crop protection industry. It equally facilitates the development of new advanced materials and supramolecular systems, and should inspire further utilization of interactions with aromatic rings to control the stereochemical outcome of synthetic transformations.},
	language = {en},
	number = {21},
	urldate = {2025-08-08},
	journal = {Angewandte Chemie International Edition},
	author = {Salonen, Laura M. and Ellermann, Manuel and Diederich, Fran{\c c}ois},
	year = {2011},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/anie.201007560},
	keywords = {molecular recognition, arenes, noncovalent interactions, receptors, biological complexation, host{\textendash}guest systems},
	pages = {4808--4842},
	file = {Snapshot:/Users/abhishektiwari/Zotero/storage/TBIKEFT5/anie.html:text/html},
}

