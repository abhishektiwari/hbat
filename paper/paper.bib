@article{afshinpour_aqcalc_2023,
	title = {{AQcalc}: {A} web server that identifies weak molecular interactions in protein structures},
	volume = {32},
	copyright = {{\textcopyright} 2023 The Protein Society.},
	issn = {1469-896X},
	shorttitle = {{AQcalc}},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/pro.4762},
	doi = {10.1002/pro.4762},
	abstract = {Weak molecular interactions play an important role in protein structure and function. Computational tools that identify weak molecular interactions are, therefore, valuable for the study of proteins. Here, we present AQcalc, a web server (https://aqcalcbiocomputing.com/) that can be used to identify anion{\textendash}quadrupole (AQ) interactions, which are weak interactions involving aromatic residue (Trp, Tyr, and Phe) ring edges and anions (Asp, Glu, and phosphate ion) both within proteins and at their interfaces (protein{\textendash}protein, protein-nucleic acids, and protein{\textendash}lipid bilayer). AQcalc identifies AQ interactions as well as clusters involving AQ, cation{\textendash}$\pi$, and salt bridges, among others. Utilizing AQcalc we analyzed weak interactions in protein models, even in the absence of experimental structures, to understand the contributions of weak interactions to deleterious structural changes, including those associated with oncogenic and germline disease variants. We identified several deleterious variants with disrupted AQ interactions (comparable in frequency to cation{\textendash}$\pi$ disruptions). Amyloid fibrils utilize AQ to bury anions at frequencies that far exceed those observed for globular proteins. AQ interactions were detected three and five times more frequently than the hydrogen-bonded AQ (HBAQ) in fibril structures and protein{\textendash}lipid bilayer interfaces, respectively. By contrast, AQ and HBAQ interactions were detected with similar frequencies in globular proteins. Collectively, these findings suggest AQcalc will be effective in facilitating fine structural analysis. As other web utilities designed to identify protein residue interaction networks do not report AQ interactions, wide use of AQcalc will enrich our understanding of residue interaction networks and facilitate hypothesis testing by identifying and experimentally characterizing these comparably weak but important interactions.},
	language = {en},
	number = {10},
	urldate = {2025-08-23},
	journal = {Protein Science},
	author = {Afshinpour, Maral and Smith, Logan A. and Chakravarty, Suvobrata},
	year = {2023},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/pro.4762},
	keywords = {AlphaFold2, anion{\textendash}quadrupole, cation{\textendash}$\pi$, disordered regions, interfaces, MemProtMD, post-translational modification, variants, weak molecular interactions},
	pages = {e4762},
	file = {Full Text PDF:/Users/abhishektiwari/Zotero/storage/RAMLLT64/Afshinpour et al. - 2023 - AQcalc A web server that identifies weak molecular interactions in protein structures.pdf:application/pdf;Snapshot:/Users/abhishektiwari/Zotero/storage/WYQ2L7RQ/pro.html:text/html},
}

